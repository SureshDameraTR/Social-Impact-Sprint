{
  "expo": {
    "name": "PashuRaksha",
    "slug": "pashuraksha",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pashuraksha",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1B6B4A"
    },
    "ios": {
      "bundleIdentifier": "org.rdo.pashuraksha",
      "supportsTablet": true
    },
    "android": {
      "package": "org.rdo.pashuraksha",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B6B4A"
      }
    },
    "supportsRTL": true,
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 5000
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font"
    ]
  }
}
