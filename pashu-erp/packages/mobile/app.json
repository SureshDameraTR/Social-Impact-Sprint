{
  "expo": {
    "name": "PashuRaksha",
    "slug": "pashuraksha",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pashuraksha",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2E7D32"
    },
    "android": {
      "package": "org.rdo.pashuraksha",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2E7D32"
      }
    },
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
