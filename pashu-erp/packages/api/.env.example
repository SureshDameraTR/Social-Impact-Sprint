# Database
# Use @db:5432 for Docker Compose, @localhost:5432 for host
DATABASE_URL=postgresql+asyncpg://pashu:YOUR_PASSWORD@localhost:5432/pashuraksha
POSTGRES_PASSWORD=YOUR_PASSWORD

# Authentication
JWT_SECRET=GENERATE_WITH_openssl_rand_-hex_32
JWT_EXPIRE_MINUTES=480

# Aadhaar hashing (dedicated secret, required in production)
AADHAAR_HASH_SECRET=<64-char-hex-secret-dedicated-to-aadhaar-hashing>

# Environment: development | production
ENVIRONMENT=development

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:8081

# Sarvam AI (required in production)
SARVAM_API_KEY=

# Rate limiting
RATE_LIMIT_PER_MINUTE=10

# Connection pool
SQL_ECHO=false
POOL_SIZE=10
MAX_OVERFLOW=20
POOL_RECYCLE=3600

# External Service URLs (point to mock-backends in development)
WEATHER_API_URL=http://localhost:8001/api/v1/weather
BHARAT_PASHUDHAN_API_URL=http://localhost:8001/api/v1/registry
IOT_GATEWAY_URL=http://localhost:8001/api/v1/iot
STORAGE_API_URL=http://localhost:8001/api/v1/storage

# Open-Meteo (free, no API key needed)
OPEN_METEO_BASE_URL=https://api.open-meteo.com
WEATHER_CACHE_TTL_SECONDS=10800

# data.gov.in (free key from https://data.gov.in)
DATA_GOV_IN_API_KEY=
DATA_GOV_IN_BASE_URL=https://api.data.gov.in

# S3 / MinIO (file storage)
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=pashuraksha
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=ap-south-1
